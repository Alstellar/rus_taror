# .env.example file (for reference only)

PYTHONIOENCODING=utf-8
LANG=C.UTF-8
LC_ALL=C.UTF-8

# --- Bot Settings ---
BOT_TOKEN="" # Your Telegram bot token from @BotFather
BOT_ADMIN_IDS="" # Admin IDs через запятую (например: 123456789,987654321)
LOG_GROUP_ID=""
CHANNEL_ID_TARO=""
CHANNEL_ID_MFN=""

# --- SambaNova LLM Settings ---
SAMBANOVA_API_KEY="" # Your SambaNova API key
SAMBANOVA_MODEL="Llama-4-Maverick-17B-128E-Instruct"

# --- PostgreSQL Settings ---
DB_HOST="localhost"
DB_USER="postgres"
DB_PASSWORD="" # Your database password
DB_NAME="taro_bot"
DB_PORT=5432

# --- YooKassa Settings ---
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""